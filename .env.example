NODE_ENV=production
PORT=5055
HOST=0.0.0.0
DATABASE_URL=mysql://user:password@host:3306/contractsense
JWT_SECRET=replace-with-long-random-secret
APP_ID=replace-with-app-id
CORS_ORIGINS=https://yourapp.com,https://www.yourapp.com
EXPO_PUBLIC_API_BASE_URL=https://api.apoteka24.me
LOCAL_UPLOADS_DIR=/home/knoxr/contractsense-ai/uploads
STORAGE_PUBLIC_BASE_URL=https://api.apoteka24.me

# --- Ops ---
OPS_METRICS_TOKEN=replace-with-ops-metrics-token
ANALYSIS_RETENTION_SWEEP_MS=3600000
ANALYSIS_QUEUE_CONCURRENCY=2
ANALYSIS_QUEUE_MAX_SIZE=100
ANALYSIS_JOB_TTL_MS=86400000

# --- App Store / mobile release ---
IOS_BUILD_NUMBER=1
ANDROID_VERSION_CODE=1
PRIVACY_POLICY_URL=https://yourapp.com/privacy
TERMS_OF_USE_URL=https://yourapp.com/terms
EAS_APPLE_ID=ios-release@example.com
IOS_SUBSCRIPTION_PRODUCT_ID=contractsense.premium.monthly
ANDROID_SUBSCRIPTION_PRODUCT_ID=contractsense_premium_monthly
APPLE_SHARED_SECRET=replace-with-app-store-connect-shared-secret
APPLE_BUNDLE_ID=com.yourcompany.contractsense